# Vercel Blob (get from `vercel env pull` or dashboard)
BLOB_READ_WRITE_TOKEN=

# Turso libSQL database
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Public base URL used when building snap/reveal links.
# Leave unset in prod — resolved from VERCEL_URL. Set for local dev if you want ngrok etc.
PUBLIC_BASE_URL=http://localhost:3000
